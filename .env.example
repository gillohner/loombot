# loombot secrets & runtime flags
#
# Copy this file to `.env.local` and fill in the real values. Everything that
# is NOT a secret lives in `config.yaml` (copy from `config.example.yaml`).

# --- Required ---------------------------------------------------------------

# Telegram bot token from @BotFather.
BOT_TOKEN=your_telegram_bot_token_here

# --- Optional runtime flags -------------------------------------------------

NODE_ENV=development
DEBUG=0
LOG_MIN_LEVEL=info
LOG_PRETTY=0

# Path to the YAML operator config. Defaults to ./config.yaml
# CONFIG_FILE=./config.yaml

# Set to 1 to run in webhook mode (production). Default is polling.
WEBHOOK=0

# SQLite path (defaults to ./bot.sqlite)
# LOCAL_DB_URL=./bot.sqlite

# --- Pubky (only if pubky.enabled: true in config.yaml) --------------------

# Passphrase for the .pkarr recovery file referenced from config.yaml.
# The file path itself lives in config.yaml under `pubky.recovery_file`.
PUBKY_PASSPHRASE=
